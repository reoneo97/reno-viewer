DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

S3_ENDPOINT_URL=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com
S3_ACCESS_KEY=your_r2_access_key
S3_SECRET_KEY=your_r2_secret_key
S3_BUCKET=reno-viewer
S3_PRESIGN_EXPIRES=86400

AUTH_USERNAME=reo
# generate with: python -c "import bcrypt,base64; print(base64.b64encode(bcrypt.hashpw(b'yourpassword', bcrypt.gensalt())).decode())"
AUTH_PASSWORD_HASH=your_base64_encoded_bcrypt_hash
JWT_SECRET=your_random_hex_string
JWT_EXPIRE_HOURS=72
