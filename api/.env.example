DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

S3_ENDPOINT_URL=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com
S3_ACCESS_KEY=your_r2_access_key
S3_SECRET_KEY=your_r2_secret_key
S3_BUCKET=reno-viewer
S3_PRESIGN_EXPIRES=86400

# Seed credentials for the FIRST account only — used when the users table is
# empty (fresh deploy). After that, manage accounts in-app (avatar menu →
# Manage users). Provide the password either as plaintext:
AUTH_USERNAME=reo
AUTH_PASSWORD=changeme
# ...or as a base64-encoded bcrypt hash (keeps $ signs out of env files):
# python -c "import bcrypt,base64; print(base64.b64encode(bcrypt.hashpw(b'changeme', bcrypt.gensalt())).decode())"
# AUTH_PASSWORD_HASH=...

JWT_SECRET=your_random_hex_string
JWT_EXPIRE_HOURS=72
