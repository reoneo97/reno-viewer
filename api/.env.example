DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

S3_ENDPOINT_URL=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com
S3_ACCESS_KEY=your_r2_access_key
S3_SECRET_KEY=your_r2_secret_key
S3_BUCKET=reno-viewer
S3_PUBLIC_URL=https://your-bucket.r2.dev

AUTH_USERNAME=reo
AUTH_PASSWORD_HASH=<bcrypt hash — generate with: python -c "import bcrypt; print(bcrypt.hashpw(b'yourpassword', bcrypt.gensalt()).decode())">
JWT_SECRET=<random hex — generate with: python -c "import secrets; print(secrets.token_hex(32))">
JWT_EXPIRE_HOURS=72
